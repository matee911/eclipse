{
  "name": "eclipse-viewer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bdd": "bddgen && playwright test",
    "test:all": "npm run test && npm run test:bdd",
    "lint": "eslint src --ext .ts,.svelte",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@testing-library/svelte": "^5.4.2",
    "@tsconfig/svelte": "^5.0.8",
    "@turf/boolean-valid": "^7.3.5",
    "@turf/kinks": "^7.3.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "playwright-bdd": "^9.2.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@turf/buffer": "^7.3.5",
    "@turf/difference": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/union": "^7.3.5",
    "i18next": "^26.3.3",
    "leaflet": "^1.9.4"
  },
  "lint-staged": {
    "src/**/*.{ts,svelte}": [
      "vitest run --reporter=verbose"
    ]
  }
}
